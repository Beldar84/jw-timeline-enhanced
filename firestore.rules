rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isRealtimeParticipant() {
      return signedIn()
        && request.auth.uid in resource.data.participantAuthIds
        && resource.data.deck.size() == 0;
    }

    function onlyUpdatesOwnHeartbeat() {
      return isRealtimeParticipant()
        && onlyChanges(['lastSeenAt', 'updatedAt'])
        && request.resource.data.lastSeenAt
          .diff(resource.data.get('lastSeenAt', {}))
          .affectedKeys()
          .hasOnly([request.auth.uid]);
    }

    // Private account document: email, friends and notification settings are
    // never exposed to other users. Social lists are changed only by validated
    // Cloud Functions, while clients may edit their own presentation settings.
    match /users/{userId} {
      allow read: if owns(userId);
      allow create: if owns(userId)
        && request.resource.data.id == userId
        && request.resource.data.friends is list
        && request.resource.data.friendRequests is list
        && request.resource.data.friends.size() == 0
        && request.resource.data.friendRequests.size() == 0;
      allow update: if owns(userId) && onlyChanges([
        'name',
        'nameLower',
        'searchPrefixes',
        'avatar',
        'updatedAt',
        'notificationToken',
        'notificationsEnabled'
      ]);
      allow delete: if owns(userId);
    }

    // Public, searchable projection maintained by Cloud Functions. It contains
    // no email address or social lists and clients can never write it directly.
    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Competitive scores are derived exclusively by authoritative game
    // functions. Progress sync remains private in userStats.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if false;
    }

    match /competitiveStats/{userId} {
      allow read: if owns(userId);
      allow write: if false;
    }

    match /userStats/{userId} {
      allow read, create, update, delete: if owns(userId);
    }

    match /gameInvitations/{invitationId} {
      allow read: if signedIn()
        && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // All game state changes are performed with the Admin SDK in callable
    // functions. Players can only read games they actually participate in.
    match /turnBasedGames/{gameId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.playerIds
        && resource.data.deck.size() == 0
        && resource.data.playerHands.size() == 0;
      allow write: if false;

      match /hands/{playerId} {
        allow read: if owns(playerId)
          && request.auth.uid in get(/databases/$(database)/documents/turnBasedGames/$(gameId)).data.playerIds;
        allow write: if false;
      }

      match /private/{documentId} {
        allow read, write: if false;
      }
    }

    match /realtimeGames/{gameId} {
      allow read: if isRealtimeParticipant();
      allow create, delete: if false;
      allow update: if onlyUpdatesOwnHeartbeat();

      match /hands/{playerId} {
        allow read: if owns(playerId)
          && request.auth.uid in get(/databases/$(database)/documents/realtimeGames/$(gameId)).data.participantAuthIds;
        allow write: if false;
      }

      match /private/{documentId} {
        allow read, write: if false;
      }
    }

    match /gameHistory/{historyId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.mode in ['local', 'ai'];
      allow update, delete: if false;
    }
  }
}
