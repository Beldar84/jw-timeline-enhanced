rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function addsSelfToList(field) {
      return signedIn()
        && onlyChanges([field])
        && request.resource.data[field].hasAll(resource.data[field])
        && request.resource.data[field].size() == resource.data[field].size() + 1
        && request.auth.uid in request.resource.data[field];
    }

    function removesSelfFromList(field) {
      return signedIn()
        && onlyChanges([field])
        && resource.data[field].hasAll(request.resource.data[field])
        && resource.data[field].size() == request.resource.data[field].size() + 1
        && !(request.auth.uid in request.resource.data[field]);
    }

    function addsSelfAsAcceptedFriend(userId) {
      return addsSelfToList('friends')
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.friendRequests.hasAny([userId]);
    }

    function mutualFriend(otherId) {
      return signedIn()
        && otherId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.friends
        && request.auth.uid in get(/databases/$(database)/documents/users/$(otherId)).data.friends;
    }

    function validPublicProfile(userId) {
      return request.resource.data.keys().hasOnly([
          'id', 'name', 'nameLower', 'searchPrefixes', 'avatar', 'updatedAt'
        ])
        && request.resource.data.id == userId
        && request.resource.data.name is string
        && request.resource.data.nameLower is string
        && request.resource.data.searchPrefixes is list;
    }

    // El documento completo sigue siendo privado. Dos amigos mutuos pueden
    // obtenerlo individualmente para migrar amistades anteriores, pero nunca
    // se permiten consultas/listados sobre la colección users.
    match /users/{userId} {
      allow get: if owns(userId) || (signedIn() && mutualFriend(userId));
      allow list: if false;
      allow create: if owns(userId)
        && request.resource.data.id == userId
        && request.resource.data.friends is list
        && request.resource.data.friendRequests is list
        && request.resource.data.friends.size() == 0
        && request.resource.data.friendRequests.size() == 0;
      allow update: if (
          owns(userId) && onlyChanges([
            'name', 'nameLower', 'searchPrefixes', 'avatar', 'updatedAt',
            'notificationToken', 'notificationsEnabled', 'friends', 'friendRequests'
          ])
        )
        || addsSelfToList('friendRequests')
        || addsSelfAsAcceptedFriend(userId)
        || removesSelfFromList('friends');
      allow delete: if owns(userId);
    }

    // Proyección buscable sin correo ni listas sociales. Cada cuenta mantiene
    // únicamente su propia ficha, por lo que no necesita Cloud Functions.
    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if owns(userId) && validPublicProfile(userId);
      allow delete: if owns(userId);
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if false;
    }

    match /competitiveStats/{userId} {
      allow read: if owns(userId);
      allow write: if false;
    }

    match /userStats/{userId} {
      allow read, create, update, delete: if owns(userId);
    }

    match /gameInvitations/{invitationId} {
      allow read: if signedIn()
        && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.gameMode in ['realtime', 'turnbased']
        && mutualFriend(request.resource.data.toUserId);
      allow update: if signedIn()
        && resource.data.toUserId == request.auth.uid
        && onlyChanges(['status'])
        && request.resource.data.status in ['accepted', 'declined'];
      allow delete: if false;
    }

    // El modo por turnos continúa reservado al backend autoritativo opcional.
    match /turnBasedGames/{gameId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.playerIds
        && resource.data.deck.size() == 0
        && resource.data.playerHands.size() == 0;
      allow write: if false;

      match /hands/{playerId} {
        allow read: if owns(playerId)
          && request.auth.uid in get(/databases/$(database)/documents/turnBasedGames/$(gameId)).data.playerIds;
        allow write: if false;
      }

      match /private/{documentId} {
        allow read, write: if false;
      }
    }

    // Partida en tiempo real compatible con Spark. La sala solo es visible
    // antes de empezar o para sus participantes. Un usuario nuevo únicamente
    // puede añadirse a una sala que todavía está en el lobby.
    match /realtimeGames/{gameId} {
      allow get: if signedIn()
        && (
          !exists(/databases/$(database)/documents/realtimeGames/$(gameId))
          || request.auth.uid in resource.data.participantAuthIds
          || resource.data.phase == 'LOBBY'
        );
      allow list: if false;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantAuthIds
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn() && (
        request.auth.uid in resource.data.participantAuthIds
        || (
          resource.data.phase == 'LOBBY'
          && request.auth.uid in request.resource.data.participantAuthIds
          && request.resource.data.participantAuthIds.hasAll(resource.data.participantAuthIds)
          && request.resource.data.participantAuthIds.size() == resource.data.participantAuthIds.size() + 1
          && request.resource.data.players.size() == resource.data.players.size() + 1
          && onlyChanges(['players', 'participantAuthIds', 'message', 'updatedAt'])
        )
      );
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;

      match /hands/{playerId} {
        allow read, write: if false;
      }

      match /private/{documentId} {
        allow read, write: if false;
      }
    }

    match /gameHistory/{historyId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.mode in ['local', 'ai'];
      allow update, delete: if false;
    }
  }
}
